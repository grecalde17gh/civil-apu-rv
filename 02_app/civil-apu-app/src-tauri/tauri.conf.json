{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Civil APU RV Desktop Prototype",
  "version": "0.1.0",
  "identifier": "ec.com.civilapurv.desktopprototype",
  "build": {
    "beforeDevCommand": {
      "script": "npm run dev",
      "wait": true
    },
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Civil APU RV - Desktop Prototype",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
